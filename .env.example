# Sports AI Predictor - Environment Variables
# Copy this file to .env and fill in your API keys

# ===== DATA SOURCES =====

# API-Football (https://www.api-football.com/)
# Free plan: 100 requests/day
FOOTBALL_API_KEY=your_api_football_key_here

# The Odds API (https://the-odds-api.com/)
# Free plan: 500 requests/month
ODDS_API_KEY=your_odds_api_key_here

# Football-Data.org (https://www.football-data.org/)
# Free plan: 10 requests/minute
FOOTBALL_DATA_API_KEY=your_football_data_key_here

# ===== NOTIFICATIONS =====

# Telegram Bot (Create via @BotFather on Telegram)
# 1. Open Telegram and search @BotFather
# 2. Send /newbot and follow instructions
# 3. Copy the token here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# Telegram Chat ID (Get via @userinfobot on Telegram)
# 1. Open Telegram and search @userinfobot
# 2. Send /start
# 3. Copy your chat ID here
TELEGRAM_CHAT_ID=your_chat_id
